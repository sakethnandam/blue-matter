{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Blue Matter Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "Build Blue Matter",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      }
    },
    {
      "name": "Run Blue Matter Extension (no build)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/out/**/*.js"
      ],
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      }
    },
    {
      "name": "Run Blue Matter Extension (open test folder)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${env:BLUE_MATTER_TEST_FOLDER}",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "Build Blue Matter",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      }
    }
  ]
}
