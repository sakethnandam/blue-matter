# Copy this file to .env and fill in your keys. Do not commit .env.
UNTITLED_YOUTUBE_API_KEY=
UNTITLED_LLM_API_KEY=
UNTITLED_LLM_PROVIDER=openai
# For OpenRouter (free models): set UNTITLED_LLM_PROVIDER=openrouter and use your OpenRouter API key in UNTITLED_LLM_API_KEY
UNTITLED_OPENROUTER_MODEL=google/gemma-3-4b-it:free
