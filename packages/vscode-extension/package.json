{
  "name": "blue-matter",
  "displayName": "Blue Matter for VS Code",
  "description": "Context-aware AI explanations for any code you select. Understands your repo, caches results, and explains in plain English.",
  "version": "0.1.0",
  "publisher": "blue-matter",
  "icon": "assets/blue-matter.png",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/sakethnandam/blue-matter"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Education"
  ],
  "keywords": ["ai", "code explanation", "openrouter", "learning", "productivity"],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bluematter.explainCode",
        "title": "Blue Matter: Explain Selected Code"
      },
      {
        "command": "bluematter.explainFile",
        "title": "Blue Matter: Explain Current File"
      },
      {
        "command": "bluematter.addAnnotation",
        "title": "Blue Matter: Add Annotation"
      },
      {
        "command": "bluematter.searchAnnotations",
        "title": "Blue Matter: Search Annotations"
      },
      {
        "command": "bluematter.openPanel",
        "title": "Blue Matter: Open Explanation Panel"
      },
      {
        "command": "bluematter.showDashboard",
        "title": "Blue Matter: Show Dashboard"
      },
      {
        "command": "bluematter.indexWorkspace",
        "title": "Blue Matter: Index Workspace"
      },
      {
        "command": "bluematter.settings",
        "title": "Blue Matter: Open Settings"
      },
      {
        "command": "bluematter.setApiKey",
        "title": "Blue Matter: Set API Key"
      },
      {
        "command": "bluematter.clearStoredApiKey",
        "title": "Blue Matter: Clear Stored API Key"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "bluematter.explainCode",
          "when": "editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "bluematter.addAnnotation",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Blue Matter",
      "properties": {
        "bluematter.openRouterModel": {
          "type": "string",
          "default": "nvidia/nemotron-3-nano-30b-a3b:free",
          "description": "Open Router model id (when apiProvider is openrouter). Free: nvidia/nemotron-3-nano-30b-a3b:free, meta-llama/llama-3.3-70b-instruct:free, stepfun/step-3.5-flash:free"
        },
        "bluematter.privacyMode": {
          "type": "string",
          "enum": ["standard", "strict"],
          "default": "standard",
          "description": "Privacy mode: standard (sends selected code to OpenRouter AI) or strict (cache-only, no code is ever sent)"
        },
        "bluematter.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Auto-index workspace on startup"
        },
        "bluematter.explanationsPerHour": {
          "type": "number",
          "default": 100,
          "description": "Max AI explanations per hour (free tier)"
        }
      }
    },
    "keybindings": [
      {
        "command": "bluematter.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "bluematter.explainFile",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f"
      },
      {
        "command": "bluematter.addAnnotation",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "node esbuild.mjs",
    "bundle:watch": "node esbuild.mjs --watch",
    "compile": "tsc -p . --noEmit",
    "watch": "tsc -watch -p . --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@blue-matter/core": "file:../core",
    "marked": "17.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^22.10.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
