# Source — only ship compiled output
src/**
**/*.ts
!**/*.d.ts
tsconfig.json
tsconfig*.json

# Tests
**/*.test.js
**/*.test.d.ts
**/*.spec.js

# Source maps — reduce VSIX size
out/**/*.js.map

# Dev tooling
.eslintrc*
.prettierrc*
jest.config*
.vscode/**
!.vscode/extensions.json

# Root-level monorepo files that must not end up in the package
../../node_modules/**
../../package.json
../../package-lock.json
../../README.md

# Local dev artifacts
.env
.env.*
*.vsix
